<!DOCTYPE html>
<html lang="{{ app.request.locale|slice(0, 2) }}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ 'sylius_stancer.ui.redirecting_to_payment'|trans }}</title>
    <meta http-equiv="refresh" content="0;url={{ stancer_url }}">
    <style>
        body { font-family: sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; margin: 0; background: #f8f9fa; }
        .box { text-align: center; padding: 2rem; max-width: 480px; }
        .spinner { width: 40px; height: 40px; border: 4px solid #dee2e6; border-top-color: #6c757d; border-radius: 50%; animation: spin 0.8s linear infinite; margin: 0 auto 1.5rem; }
        @keyframes spin { to { transform: rotate(360deg); } }
        p { color: #6c757d; margin-bottom: 1.5rem; }
        a.btn { display: inline-block; padding: .5rem 1.25rem; background: #212529; color: #fff; text-decoration: none; border-radius: .375rem; font-size: .9rem; }
        a.btn:hover { background: #000; }
        .fallback { margin-top: 2rem; font-size: .8rem; color: #adb5bd; }
        .fallback a { color: #6c757d; }
    </style>
</head>
<body>
    <div class="box">
        <div class="spinner"></div>
        <p>{{ 'sylius_stancer.ui.redirecting_to_payment'|trans }}</p>
        <a href="{{ stancer_url }}" class="btn">{{ 'sylius_stancer.ui.go_to_payment'|trans }}</a>
        <div class="fallback">
            <a href="{{ return_url }}">{{ 'sylius_stancer.ui.return_to_shop'|trans }}</a>
        </div>
    </div>
</body>
</html>
