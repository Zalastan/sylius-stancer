{
    "name": "spiderweb/sylius-stancer-plugin",
    "description": "Sylius plugin for Stancer payment gateway",
    "type": "sylius-plugin",
    "license": "MIT",
    "authors": [
        {
            "name": "Spider Web",
            "homepage": "https://www.spider-web.fr"
        }
    ],
    "require": {
        "php": ">=8.2",
        "stancer/stancer": "^2.0",
        "sylius/core-bundle": "^2.0",
        "sylius/payment-bundle": "^2.0",
        "symfony/form": "^6.4 || ^7.0",
        "symfony/messenger": "^6.4 || ^7.0"
    },
    "conflict": {
        "payum/core": "*",
        "sylius/payum-bundle": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "SpiderWeb\\Sylius\\StancerPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "SpiderWeb\\Sylius\\StancerPlugin\\Tests\\": "tests/"
        }
    },
    "keywords": ["stancer", "payment", "sylius", "sylius-plugin"],
    "homepage": "https://www.spider-web.fr"
}
